# Environment variables

# Database connection string (SQLite file path)
# Default: ./db/data.db
# Examples: ./db/data.db, /tmp/todos.db
DATABASE_URL=./db/data.db

# Storage provider for attachments
# Options: local (file system), s3 (AWS S3)
# Default: local
STORAGE_PROVIDER=local

# Public base URL for the application
# Used for generating absolute URLs in emails, exports, etc.
# Default: http://localhost:3000
# Examples: http://localhost:3000, https://todo.example.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# AWS S3 configuration (required if STORAGE_PROVIDER=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=your-bucket-name
